<Window x:Class="ScheduledHttpTasks.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="帮助与支持" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <!-- <TextBlock Grid.Row="0" Text="帮助与支持" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" /> -->
        
        <!-- 联系信息 -->
        <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
            <TextBlock Text="如有问题请联系：" FontSize="12" />

        </StackPanel>
        
        <!-- 二维码图片 -->
        <Image Grid.Row="2" x:Name="QrCodeImage" Width="250" Height="250" HorizontalAlignment="Center" Margin="0,0,0,30" />
        
        <!-- 关闭按钮 -->
        <Button Grid.Row="3" Content="关闭" Width="80" Height="30" HorizontalAlignment="Center" Click="CloseButton_Click" />
    </Grid>
</Window>