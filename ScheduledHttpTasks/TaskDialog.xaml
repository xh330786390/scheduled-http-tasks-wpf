
<Window x:Class="ScheduledHttpTasks.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScheduledHttpTasks"
        mc:Ignorable="d"
        Title="任务配置"
        Height="800" Width="800"
        MinHeight="800" MinWidth="800"
        MaxHeight="1000" MaxWidth="1000"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="120" />
            <RowDefinition Height="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 任务名称 -->
        <Label Grid.Row="0" Grid.Column="0" Content="任务名称:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Task.Name}" Margin="0,8" />

        <!-- 时间设置 -->
        <Label Grid.Row="1" Grid.Column="0" Content="执行间隔:" VerticalAlignment="Center" />
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding Task.CronExpression}" Margin="0,0,5,0" ToolTip="Cron表达式，格式：秒 分 时 日 月 星期" />
            <Button Grid.Column="1" Content="设置间隔" Click="SetTime_Click" />
        </Grid>



        <!-- URL -->
        <Label Grid.Row="2" Grid.Column="0" Content="API URL:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Task.Url}" Margin="0,8" />

        <!-- 方法 -->
        <Label Grid.Row="3" Grid.Column="0" Content="请求方法:" VerticalAlignment="Center" />
        <ComboBox Grid.Row="3" Grid.Column="1" SelectedValue="{Binding Task.Method}" SelectedValuePath="Content" Margin="0,8">
            <ComboBoxItem Content="GET" />
            <ComboBoxItem Content="POST" />
        </ComboBox>

        <!-- 解析 CURL -->
        <Label Grid.Row="4" Grid.Column="0" Content="解析 CURL:" VerticalAlignment="Center" />
        <Grid Grid.Row="4" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding CurlText}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="60" />
            <Button Grid.Column="1" Content="解析" Command="{Binding ParseCurlCommand}" Margin="5,0" />
        </Grid>

        <!-- 请求头 -->
        <Label Grid.Row="5" Grid.Column="0" Content="请求头:" VerticalAlignment="Top" />
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Task.Headers}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="110"/> <!-- Margin="0,10" /> -->

        <!-- 请求体 -->
        <Label Grid.Row="6" Grid.Column="0" Content="请求体:" VerticalAlignment="Top" Margin="0,2,0,0" />
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Task.Body}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="110" Margin="0,10,0,0"/>

        <!-- 空行，为测试请求提供间距 -->
        <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Height="10" />

        <!-- 发送测试按钮 -->
        <Label Grid.Row="8" Grid.Column="0" Content="测试请求:" VerticalAlignment="Center" />
        <Button Grid.Row="8" Grid.Column="1" Content="发送测试" Width="80" Height="30" Click="SendTest_Click" Margin="0,8" HorizontalAlignment="Left" />

        <!-- 执行情况文本框 -->
        <Label Grid.Row="9" Grid.Column="0" Content="执行情况:" VerticalAlignment="Top" />
        <TextBox Grid.Row="9" Grid.Column="1" x:Name="TestResultTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="120" IsReadOnly="True" Background="#FFF0F0F0" />

        <!-- 空行，确保按钮有足够空间 -->
        <Grid Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Height="30" />

        <!-- 按钮 -->
        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="确定" Width="80" Height="30" IsDefault="True" Click="OK_Click" Margin="0,0,10,10" />
            <Button Content="取消" Width="80" Height="30" IsCancel="True" Margin="0,0,0,10" />
        </StackPanel>
    </Grid>
</Window>
